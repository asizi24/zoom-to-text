# ══════════════════════════════════════════════════════════════
#  Zoom Transcriber — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env or key.json to git!
# ══════════════════════════════════════════════════════════════

# ── Google AI (choose one option) ─────────────────────────────
# Option A: Gemini API Key (easier, free tier available)
# Get it at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Option B: GCP Service Account key file path
# (Used for Vertex AI — if you have key.json, leave this as-is)
GOOGLE_APPLICATION_CREDENTIALS=key.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Gemini model to use (gemini-2.5-flash is recommended for new API keys)
GEMINI_MODEL=gemini-2.5-flash

# ── Whisper settings (for WHISPER_LOCAL mode only) ─────────────
# Model sizes: tiny | base | small | medium | large-v3
# Memory needed: tiny~400MB | medium~2GB | large-v3~4GB
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Resource management ────────────────────────────────────────
# Unload Whisper from RAM after N idle minutes (saves memory)
AUTO_SHUTDOWN_IDLE_MINUTES=30

# ── App settings ───────────────────────────────────────────────
# Your server's public URL (used by the Chrome extension)
# Local:      http://localhost:8000
# EC2:        http://your-ec2-ip
# With domain: https://yourdomain.com
BASE_URL=http://localhost:8000

# ── LLM Provider Selection ────────────────────────────────────
# Which LLM handles summarization, critique, chat, and flashcards.
# Options: gemini | openrouter | ollama
LLM_PROVIDER=gemini

# OpenRouter (https://openrouter.ai) — optional, only needed if
# LLM_PROVIDER=openrouter. Get a key at openrouter.ai/keys.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama (https://ollama.com) — local model runner, optional.
# Only used if LLM_PROVIDER=ollama. Not deployed on Fly.io.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b

# ── LLM Debugging (Task 1.1) ──────────────────────────────────
# When true, persist raw LLM responses (synthesis + extraction calls)
# into result_json.raw_llm_response for offline debugging.
# Keep disabled in production — raw responses can be 50KB+ each.
LLM_DEBUG_RAW_RESPONSES=false
