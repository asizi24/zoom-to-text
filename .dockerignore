# ── Secrets — NEVER bake .env into the image ──────────────────
.env
*.pem

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# ── Virtual environments ───────────────────────────────────────
.venv/
venv/
env/

# ── Data & runtime files (mounted as Docker volumes) ──────────
data/
downloads/
uploads/
*.db
*.log

# ── Git & CI ───────────────────────────────────────────────────
.git/
.github/
.gitignore

# ── IDE & OS ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ── Legacy & test files ────────────────────────────────────────
_legacy_archive/
test_*.py
verify_*.py
demo_*.py

# ── Docs ──────────────────────────────────────────────────────
README.md

# requirements.txt MUST be included (Dockerfile COPY depends on it)
!requirements.txt
